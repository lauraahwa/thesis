# Copy this file to .env and fill in your values.
# The .env file is gitignored — never commit it.

# ---- Required ----------------------------------------------------------------

# Absolute path to your GenX.jl checkout. Cases are resolved relative to this,
# and `julia --project=<GENX_DIR>` is used to run them.
GENX_DIR=/path/to/GenX.jl

# ---- SLURM (cluster-specific) ------------------------------------------------

# Partition to submit to.
SLURM_PARTITION=all

# Default CPUs per task when the caller doesn't specify.
SLURM_CPUS_DEFAULT=4

# Email for SLURM BEGIN/END/FAIL notifications. Leave blank to disable job mail.
SLURM_MAIL_USER=example@princeton.edu

# Directory for SLURM .out/.err logs. Defaults to <GENX_DIR>/run_logs if unset.
# GENX_LOG_DIR=

# ---- Cluster modules / build (all optional) ----------------------------------
# Run `module avail` on your cluster to find the right names. Leave blank to
# skip the corresponding `module load` / export line entirely.

JULIA_MODULE=julia/1.10.5
GUROBI_MODULE=gurobi/9.0.1

# Optional JULIA_CPU_TARGET for multi-arch builds. Leave blank to skip.
JULIA_CPU_TARGET=
