# Copy this file to .env and fill in your values. .env is gitignored.

# ---- Required ----
# Absolute path to your GenX.jl checkout.
GENX_DIR=/path/to/GenX.jl

# ---- SLURM (cluster-specific) ----
SLURM_PARTITION=all
SLURM_CPUS_DEFAULT=4
SLURM_MAIL_USER=example@princeton.edu   # blank to disable job mail
# GENX_LOG_DIR=

# ---- Cluster modules / build (optional; `module avail` to find names) ----
JULIA_MODULE=julia/1.10.5
GUROBI_MODULE=gurobi/9.0.1
JULIA_CPU_TARGET=
